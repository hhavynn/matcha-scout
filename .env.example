# PostgreSQL 17 locally; use the pooled Neon connection string in production.
DATABASE_URL=postgresql://matcha:matcha@postgres:5432/matcha_scout
DATABASE_TABLE_NAME=matcha_items
DATABASE_ENVIRONMENT=local

# AI configuration
GEMINI_API_KEY=
AI_PROVIDER=gemini
# Set USE_MOCK_AI=true to skip Gemini calls during local development
USE_MOCK_AI=true

# Yelp Fusion API ingestion (local/admin only; do not commit real keys)
YELP_API_KEY=
YELP_API_BASE_URL=https://api.yelp.com/v3
YELP_DEFAULT_LOCATION=San Diego, CA
YELP_DEFAULT_TERM=matcha

# CORS allowed origins (comma-separated)
# Local default — FastAPI uses localhost:3000
# In production, set CORS_ALLOWED_ORIGINS to include the Vercel frontend URL.
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
