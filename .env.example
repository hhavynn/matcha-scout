AWS_REGION=us-west-2
DYNAMODB_ENDPOINT_URL=http://dynamodb-local:8000
DYNAMODB_TABLE_NAME=matcha_scout
# DynamoDB Local accepts any non-empty credential values
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# AI configuration
GEMINI_API_KEY=
AI_PROVIDER=gemini
# Set USE_MOCK_AI=true to skip Gemini calls during local development
USE_MOCK_AI=true

# Yelp Fusion API ingestion (local/admin only; do not commit real keys)
YELP_API_KEY=
YELP_API_BASE_URL=https://api.yelp.com/v3
YELP_DEFAULT_LOCATION=San Diego, CA
YELP_DEFAULT_TERM=matcha

# CORS allowed origins (comma-separated)
# Local default — FastAPI uses localhost:3000
# In AWS Lambda, set CORS_ALLOWED_ORIGINS to include the Vercel production URL
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
